{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=dealhunter.db"
  },
  "Telegram": {
    "BotToken": "YOUR_TELEGRAM_BOT_TOKEN_HERE"
  },
  "PollingIntervalMinutes": 5,
  "Resilience": {
    "MaxRetryCount": 3,
    "BaseBackoffSeconds": 2,
    "InterRequestDelaySeconds": 3
  },
  "Panel": {
    "WebPanelPin": "1234",
    "AdminChatId": 123456789
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
